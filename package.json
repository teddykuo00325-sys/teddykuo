{
  "name": "lingce-company",
  "version": "1.0.0",
  "description": "凌策公司 - AI Agent 驅動的軟體公司平台",
  "private": true,
  "scripts": {
    "dev:frontend": "cd src/frontend && npx vite --port 3000",
    "dev:backend": "cd src/backend && node server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd src/frontend && npx vite build",
    "start": "node src/backend/server.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
